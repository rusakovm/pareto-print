generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  passwordHash String

  telegramChatId        String?   @unique
  telegramLinkCode      String?   @unique
  telegramLinkExpiresAt DateTime?
  passwordResetCode      String?
  passwordResetExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  cartItems     CartItem[]
  favoriteItems FavoriteItem[]

  roles UserRole[]
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

model FavoriteItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}


model Role {
  id   Int    @id @default(autoincrement())
  name String @unique

  users UserRole[]
}

model UserRole {
  userId Int
  roleId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model Product {
  id          Int      @id @default(autoincrement())
  title       String
  author      String?
  description String?
  price       Int
  image       String
  category    String
  cover       String
  stock       String
  isHero      Boolean  @default(false)
  isMerch     Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems     CartItem[]
  favoriteItems FavoriteItem[]
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String
  shortText   String
  fullText    String
  image       String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  exp       String
  skill     String
  photo     String?
  bio       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pages EmployeePage[]
}

model EmployeePage {
  id         Int      @id @default(autoincrement())
  employeeId Int
  title      String
  text       String
  order      Int      @default(0)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model ContentBlock {
  id        Int      @id @default(autoincrement())
  entity    String
  entityId  Int
  type      String
  title     String?
  text      String?
  image     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entity, entityId])
}